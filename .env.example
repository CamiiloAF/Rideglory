# Las claves de Firebase se movieron a archivos dart-define por flavor:
#   config/dev.json  y  config/prod.json  (ver config/*.json.example)
# Se pasan con --dart-define-from-file=config/<flavor>.json al correr/buildear.
# Este .env solo guarda secretos no específicos del flavor.

# Optional override for the local backend URL (full URL, with /api suffix).
# - Leave empty to use the platform defaults:
#     * Android emulator -> http://10.0.2.2:3000/api
#     * iOS sim / web    -> http://localhost:3000/api
# - Set to your Mac's LAN IP when running on a physical device so it can
#   reach the gateway over Wi-Fi (same value also works on emulators/simulators).
#     e.g. LOCAL_API_BASE_URL=http://192.168.20.94:3000/api
# Remember to re-run `dart run build_runner build` after changing this.
LOCAL_API_BASE_URL=

# Mapbox token (sk.*) for Mapbox Maps SDK.
MAPBOX_ACCESS_TOKEN=
