{
  "enabledMcpjsonServers": ["stitch"],
  "permissions": {
    "allow": [
      "Write",
      "Edit"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/load-feature-docs.py 2>/dev/null || true",
            "statusMessage": "Cargando documentación del feature…",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
